# Supabase — preencha com as credenciais do seu projeto (Project Settings > API)
# Depois copie este arquivo para .env.local
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Usada apenas em scripts administrativos no servidor (NUNCA exponha no client).
# Opcional nesta etapa.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
